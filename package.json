{
  "name": "mess-manager",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "install:frontend": "npm install --prefix artifacts/mess-tracker",
    "install:backend": "npm install --prefix artifacts/api-server",
    "install:all": "npm run install:frontend && npm run install:backend",
    "build:frontend": "npm run build --prefix artifacts/mess-tracker",
    "build:backend": "npm run build --prefix artifacts/api-server",
    "build": "npm run build:frontend && npm run build:backend",
    "dev:frontend": "npm run dev --prefix artifacts/mess-tracker",
    "dev:backend": "npm run dev --prefix artifacts/api-server"
  },
  "devDependencies": {
    "typescript": "~5.9.3"
  }
}
