{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "cd artifacts/mess-tracker && npm install --ignore-scripts",
  "buildCommand": "cd artifacts/mess-tracker && npm run build",
  "outputDirectory": "artifacts/mess-tracker/dist",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
