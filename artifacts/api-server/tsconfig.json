{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@workspace/api-zod": ["./src/lib/api-zod/index.ts"],
      "@workspace/db": ["./src/lib/db/index.ts"],
      "@workspace/db/schema": ["./src/lib/db/schema/index.ts"]
    }
  },
  "include": ["src"]
}
